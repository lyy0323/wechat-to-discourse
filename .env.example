# Discourse 论坛地址
DISCOURSE_URL=https://yuan.sjtuguoxue.space

# Discourse 管理员 API Key（在 Discourse 管理后台 → API 中生成，范围选「全部用户」）
DISCOURSE_API_KEY=

# DiscourseConnect Provider 共享密钥
# 在 Discourse 管理后台 → 设置 → 登录 中：
# 1. 启用 enable_discourse_connect_provider
# 2. 在 discourse_connect_provider_secrets 中添加：你的回调URL|这个密钥
#    例如：https://your-app.vercel.app/api/auth/callback|your_secret_here
DISCOURSE_CONNECT_SECRET=

# 用于签名会话 cookie 的密钥（随机字符串，至少 32 位）
SESSION_SECRET=

# 应用部署地址（本地开发用 http://localhost:3000）
NEXT_PUBLIC_APP_URL=http://localhost:3000
